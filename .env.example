# API URL must be https://<project-ref>.supabase.co (Project Settings → API).
# Do NOT use the dashboard link (https://supabase.com/dashboard/project/...).
EXPO_PUBLIC_SUPABASE_URL=
# Project Settings → API → anon public key (long JWT starting with eyJ...).
EXPO_PUBLIC_SUPABASE_ANON_KEY=
#
# Supabase → Authentication → URL Configuration:
# - Site URL: app entry only (e.g. exp://YOUR_IP:8082 for Expo Go, or swipemarket://).
#   Do NOT set Site URL to /onboarding — onboarding is in-app routing after sign-in.
# - Email: Authentication → Providers → Email → enable "Confirm email" for password sign-ups
#   (the app sets emailRedirectTo → /auth/callback).
# - Redirect URLs: add BOTH URLs Metro logs in dev when you tap "Sign in with Google":
#   — line "OAuth + email confirm" (callback)
#   — line "password reset" (reset link target)
#   Also add swipemarket://auth/callback and swipemarket://auth/reset-password for native builds.
#   Example Expo Go: exp://192.168.x.x:8082/--/auth/callback and .../--/auth/reset-password
#
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
EXPO_PUBLIC_SOCKET_URL=
